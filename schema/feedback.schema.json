{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-field-notes.local/schema/feedback@1",
  "title": "LLM Field Notes feedback dataset",
  "description": "Reviewed graph items exported for extractor evaluation or improvement.",
  "type": "object",
  "required": ["format", "graphSchema", "exportedAt", "examples"],
  "properties": {
    "format": { "const": "llm-field-notes/feedback@1" },
    "graphSchema": { "const": "llm-field-notes/graph@1" },
    "exportedAt": { "type": "string", "format": "date-time" },
    "datasetFingerprint": { "type": "string", "pattern": "^fnv1a-[0-9a-f]{8}(?:[0-9a-f]{8})?$" },
    "examples": {
      "type": "array",
      "maxItems": 15000,
      "items": {
        "type": "object",
        "required": ["kind", "id", "status", "confidence", "feedback", "evidence", "sources"],
        "properties": {
          "kind": { "enum": ["concept", "relation"] },
          "id": { "type": "string", "minLength": 1, "maxLength": 200 },
          "aliases": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 120 } },
          "label": { "type": "string", "maxLength": 120 },
          "source": { "type": "string", "maxLength": 200 },
          "sourceLabel": { "type": "string", "maxLength": 120 },
          "target": { "type": "string", "maxLength": 200 },
          "targetLabel": { "type": "string", "maxLength": 120 },
          "status": { "enum": ["accepted", "rejected"] },
          "lastReviewedAt": { "type": ["string", "null"], "format": "date-time", "maxLength": 128 },
          "confidence": { "type": "number", "minimum": 0.01, "maximum": 0.99 },
          "feedback": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
          "evidence": { "type": "array", "maxItems": 8, "items": { "$ref": "#/$defs/evidence" } },
          "sources": { "type": "array", "maxItems": 200, "items": { "type": "string", "maxLength": 200 } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["text", "sources"],
      "properties": {
        "text": { "type": "string", "maxLength": 12000 },
        "sources": {
          "type": "array",
          "maxItems": 200,
          "items": { "type": "string", "maxLength": 200 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  }
}
