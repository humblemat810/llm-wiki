{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-field-notes.local/schema/extractor-request@1",
  "title": "LLM Field Notes extraction request",
  "description": "Same-origin request envelope for optional model-backed extraction.",
  "type": "object",
  "required": ["operation", "schema", "feedbackFormat", "document", "feedback"],
  "properties": {
    "operation": { "const": "extract-graph" },
    "schema": { "const": "llm-field-notes/graph@1" },
    "feedbackFormat": { "const": "llm-field-notes/feedback@1" },
    "document": {
      "type": "object",
      "required": ["title", "text"],
      "properties": {
        "title": { "type": "string", "maxLength": 200 },
        "uri": { "type": "string", "maxLength": 2048, "pattern": "^(?:(?:https?|file|urn|doi):|[^:]+$)" },
        "text": { "type": "string", "minLength": 40, "maxLength": 300000 }
      },
      "additionalProperties": false
    },
    "feedback": {
      "type": "array",
      "maxItems": 500,
      "items": { "$ref": "#/$defs/feedbackHint" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "feedbackHint": {
      "type": "object",
      "required": ["kind", "id", "status"],
      "properties": {
        "kind": { "enum": ["concept", "relation"] },
        "id": { "type": "string", "minLength": 1, "maxLength": 200 },
        "label": { "type": "string", "maxLength": 120 },
        "aliases": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 120 }, "uniqueItems": true },
        "source": { "type": "string", "maxLength": 200 },
        "sourceLabel": { "type": "string", "maxLength": 120 },
        "target": { "type": "string", "maxLength": 200 },
        "targetLabel": { "type": "string", "maxLength": 120 },
        "status": { "enum": ["accepted", "rejected"] }
      },
      "additionalProperties": false
    }
  }
}
