{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "encrypted-backup.schema.json",
  "title": "LLM Field Notes encrypted full backup",
  "description": "Password-encrypted wrapper around a versioned full backup. The password is never part of this envelope.",
  "type": "object",
  "required": ["format", "version", "cipher", "kdf", "iterations", "salt", "iv", "ciphertext"],
  "properties": {
    "format": { "const": "llm-field-notes/encrypted-backup@1" },
    "version": { "const": 1 },
    "cipher": { "const": "AES-GCM-256" },
    "kdf": { "const": "PBKDF2-SHA-256" },
    "iterations": { "const": 250000 },
    "salt": { "type": "string", "minLength": 24, "maxLength": 24, "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$" },
    "iv": { "type": "string", "minLength": 16, "maxLength": 16, "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$" },
    "ciphertext": { "type": "string", "minLength": 24, "maxLength": 69905088, "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$" }
  },
  "additionalProperties": false
}
