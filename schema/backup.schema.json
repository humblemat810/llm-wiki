{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "backup.schema.json",
  "title": "LLM Field Notes full backup",
  "description": "Graph state plus bounded undo history for local restoration.",
  "type": "object",
  "required": ["format", "exportedAt", "graph", "history"],
  "properties": {
    "format": { "const": "llm-field-notes/backup@1" },
    "exportedAt": { "type": "string", "format": "date-time" },
    "graphFingerprint": { "type": "string", "pattern": "^fnv64-[0-9a-f]{16}-[0-9]+$" },
    "graph": { "$ref": "graph.schema.json" },
    "history": {
      "type": "array",
      "maxItems": 3,
      "items": { "$ref": "graph.schema.json" }
    }
  },
  "additionalProperties": false
}
