{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-field-notes.example/schema/vault-manifest.schema.json",
  "title": "LLM Field Notes vault manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "graphSchema", "graphVersion", "graphFingerprint", "redacted", "generatedAt"],
  "properties": {
    "format": { "const": "llm-field-notes/vault@1" },
    "graphSchema": { "const": "llm-field-notes/graph@1" },
    "graphVersion": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "graphFingerprint": { "type": "string", "maxLength": 128, "pattern": "^fnv64-[0-9a-f]{16}-[0-9]+$" },
    "appVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
    "redacted": { "type": "boolean" },
    "generatedAt": { "type": "string", "format": "date-time", "maxLength": 128 },
    "learning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "included", "unavailable", "complete"],
      "properties": {
        "requested": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "included": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "unavailable": {
          "type": "array",
          "maxItems": 1000,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        },
        "complete": { "type": "boolean" }
      }
    }
  }
}
