{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-field-notes.local/schema/graph@1",
  "title": "LLM Field Notes knowledge graph",
  "description": "Portable internal representation used by the browser graph, backups, and external projections.",
  "type": "object",
  "required": ["schema", "version", "documents", "nodes", "edges", "revisions"],
  "properties": {
    "schema": {
      "const": "llm-field-notes/graph@1"
    },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "updatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "documents": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/document" }
    },
    "nodes": {
      "type": "array",
      "maxItems": 5000,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/edge" }
    },
    "revisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/revision" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["text", "sources"],
      "properties": {
        "text": { "type": "string" },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "document": {
      "type": "object",
      "required": ["id", "title", "text", "fingerprint", "addedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "text": { "type": "string" },
        "fingerprint": { "type": "string", "minLength": 1 },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "required": ["id", "label", "aliases", "type", "confidence", "mentions", "feedback", "status", "sources", "evidence", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "aliases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "type": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0.01, "maximum": 0.99 },
        "mentions": { "type": "integer", "minimum": 1 },
        "feedback": { "type": "integer" },
        "status": { "enum": ["inferred", "accepted", "rejected"] },
        "sources": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target", "label", "confidence", "evidence", "sources", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "confidence": { "type": "number", "minimum": 0.01, "maximum": 0.99 },
        "feedback": { "type": "integer" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "sources": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "status": { "enum": ["inferred", "accepted", "rejected"] }
      },
      "additionalProperties": true
    },
    "revision": {
      "type": "object",
      "required": ["id", "version", "timestamp", "reason", "nodes", "edges"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 0 },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "nodes": { "type": "integer", "minimum": 0 },
        "edges": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  }
}
