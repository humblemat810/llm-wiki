{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-field-notes.local/schema/health@1",
  "title": "LLM Field Notes graph health report",
  "description": "Privacy-safe diagnostics for a normalized graph representation.",
  "type": "object",
  "required": ["format", "graphSchema", "graphVersion", "inspectedAt", "health"],
  "properties": {
    "format": { "const": "llm-field-notes/health@1" },
    "graphSchema": { "const": "llm-field-notes/graph@1" },
    "graphVersion": { "type": "integer", "minimum": 0 },
    "graphFingerprint": { "type": "string", "pattern": "^fnv64-[0-9a-f]{16}-[0-9]+$" },
    "appVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
    "inspectedAt": { "type": "string", "format": "date-time" },
    "health": {
      "type": "object",
      "description": "Bounded counts and percentages only; source text and evidence are never included. Provenance coverage measures active concepts and relations, including items without evidence records.",
      "properties": {
        "documents": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "nodes": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "activeNodes": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "rejectedNodes": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "edges": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "activeEdges": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "reviewedItems": { "type": "integer", "minimum": 0, "maximum": 15000 },
        "reviewedNodes": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "reviewedEdges": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "reviewCandidates": { "type": "integer", "minimum": 0, "maximum": 15000 },
        "staleReviewCandidates": { "type": "integer", "minimum": 0, "maximum": 15000 },
        "newEvidenceReviewCandidates": { "type": "integer", "minimum": 0, "maximum": 15000 },
        "reviewQueueTruncated": { "type": "boolean" },
        "feedbackContextAvailable": { "type": "integer", "minimum": 0, "maximum": 15500 },
        "feedbackContextRetained": { "type": "integer", "minimum": 0, "maximum": 500 },
        "feedbackContextTruncated": { "type": "boolean" },
        "feedbackContextExcluded": { "type": "integer", "minimum": 0, "maximum": 15500 },
        "learningExamples": { "type": "integer", "minimum": 0, "maximum": 500 },
        "staleLearningExamples": { "type": "integer", "minimum": 0, "maximum": 500 },
        "acceptedItems": { "type": "integer", "minimum": 0, "maximum": 15000 },
        "rejectedItems": { "type": "integer", "minimum": 0, "maximum": 15000 },
        "evidenceRecords": { "type": "integer", "minimum": 0, "maximum": 120000 },
        "ambiguousLabels": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "rejectedEdges": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "reviewedSources": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "supportedNodes": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "unsupportedNodes": { "type": "integer", "minimum": 0, "maximum": 5000 },
        "supportedEdges": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "unsupportedEdges": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "orphanedSourceReferences": { "type": "integer", "minimum": 0, "maximum": 27000000 },
        "ambiguousSourceIds": { "type": "integer", "minimum": 0, "maximum": 100 },
        "ambiguousEdgeIds": { "type": "integer", "minimum": 0, "maximum": 100 },
        "ambiguousSourceReferences": { "type": "integer", "minimum": 0, "maximum": 27000000 },
        "conflictingNodeIds": { "type": "integer", "minimum": 0, "maximum": 100 },
        "conflictingEdgeIds": { "type": "integer", "minimum": 0, "maximum": 100 },
        "conflictingItems": { "type": "integer", "minimum": 0, "maximum": 200 },
        "truncated": { "type": "boolean" },
        "truncatedItems": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "truncatedDocuments": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedNodes": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedEdges": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedRevisions": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedLearningExamples": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedDocumentText": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedEvidenceText": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedEvidenceItems": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "truncatedSourceReferences": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "dropped": { "type": "boolean" },
        "droppedItems": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "droppedDocuments": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "droppedNodes": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "droppedEdges": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "droppedRevisions": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "droppedLearningExamples": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "evidenceGroundingAvailable": { "type": "boolean" },
        "evidenceGroundingCheckedRecords": { "type": "integer", "minimum": 0, "maximum": 2000 },
        "evidenceGroundingComparisons": { "type": "integer", "minimum": 0, "maximum": 250000 },
        "evidenceGroundingSourceScanChars": { "type": "integer", "minimum": 0, "maximum": 50000000 },
        "evidenceGroundingTruncated": { "type": "boolean" },
        "anchoredEvidenceRecords": { "type": "integer", "minimum": 0, "maximum": 120000 },
        "unanchoredEvidenceRecords": { "type": "integer", "minimum": 0, "maximum": 120000 },
        "evidenceGroundingCoverage": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "provenanceCoverage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "sourceReviewCoverage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "freshSourceReviewCoverage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "redacted": { "type": "boolean" },
        "sourceQuality": {
          "type": "object",
          "properties": {
            "unknown": { "type": "integer", "minimum": 0, "maximum": 1000 },
            "primary": { "type": "integer", "minimum": 0, "maximum": 1000 },
            "secondary": { "type": "integer", "minimum": 0, "maximum": 1000 },
            "tertiary": { "type": "integer", "minimum": 0, "maximum": 1000 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "reviewQueue": {
      "type": "array",
      "description": "Bounded actionable review metadata. Labels and reasons are included for routing; source text, evidence text, and source URIs are never included.",
      "maxItems": 15000,
      "items": {
        "type": "object",
        "required": ["kind", "id", "label", "priority", "confidence", "evidence", "supported", "reason"],
        "properties": {
          "kind": { "enum": ["node", "edge", "source"] },
          "id": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "label": { "type": "string", "maxLength": 2000 },
          "priority": { "type": "number", "minimum": 0, "maximum": 1000 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "integer", "minimum": 0, "maximum": 8 },
          "supported": { "type": "boolean" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 200 },
          "unanchoredEvidence": { "type": "integer", "minimum": 1, "maximum": 2000 },
          "stale": { "type": "boolean" },
          "newEvidence": { "type": "boolean" },
          "sourceQuality": { "type": "string", "enum": ["unknown", "primary", "secondary", "tertiary"] },
          "sourceReviewed": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "gate": {
      "type": "object",
      "required": ["passed", "violations", "thresholds"],
      "properties": {
        "passed": { "type": "boolean" },
      "violations": { "type": "array", "maxItems": 12, "items": { "type": "string", "maxLength": 200 } },
        "thresholds": {
          "type": "object",
          "required": ["minProvenance", "maxOrphaned", "maxAmbiguous"],
          "properties": {
            "minProvenance": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "minFreshSourceReview": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "maxOrphaned": { "type": ["integer", "null"], "minimum": 0, "maximum": 9007199254740991 },
            "maxAmbiguous": { "type": ["integer", "null"], "minimum": 0, "maximum": 9007199254740991 },
            "maxUnsupportedNodes": { "type": ["integer", "null"], "minimum": 0, "maximum": 5000 },
            "maxUnsupportedEdges": { "type": ["integer", "null"], "minimum": 0, "maximum": 10000 },
            "maxReviewCandidates": { "type": ["integer", "null"], "minimum": 0, "maximum": 15000 },
            "maxReviewQueueTruncated": { "type": ["integer", "null"], "minimum": 0, "maximum": 1 },
            "maxEvidenceGroundingTruncated": { "type": ["integer", "null"], "minimum": 0, "maximum": 1 },
            "maxFeedbackContextTruncated": { "type": ["integer", "null"], "minimum": 0, "maximum": 1 },
            "maxStaleReviewCandidates": { "type": ["integer", "null"], "minimum": 0, "maximum": 15000 },
            "maxStaleLearningExamples": { "type": ["integer", "null"], "minimum": 0, "maximum": 500 },
            "maxWithheldGuidance": { "type": ["integer", "null"], "minimum": 0, "maximum": 15500 },
            "maxUnanchoredEvidence": { "type": ["integer", "null"], "minimum": 0, "maximum": 120000 },
            "maxConflictingItems": { "type": ["integer", "null"], "minimum": 0, "maximum": 200 },
            "maxTruncatedItems": { "type": ["integer", "null"], "minimum": 0, "maximum": 9007199254740991 },
            "maxDroppedItems": { "type": ["integer", "null"], "minimum": 0, "maximum": 9007199254740991 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
